# BitStockerz API — copy to .env and adjust (never commit .env)

# Server
PORT=4000
NODE_ENV=development

# Optional MySQL (omit for in-memory seed mode)
# Local Docker: ./scripts/docker-mysql.sh start
# DATABASE_URL=mysql://bitstockerz:devpassword@localhost:3306/bitstockerz

# Jobs & ingestion (Sprint 1.3)
JOB_TIMEOUT_MS=30000
# Set false during manual testing to disable hourly background imports
INGESTION_SCHEDULER_ENABLED=false
JOBS_SYSTEM_USER_ID=00000000-0000-4000-8000-000000000001

# Auth / OAuth (Sprint 0.2 — only if testing social login)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/oauth/google/callback
# APPLE_OAUTH_CLIENT_ID=
# APPLE_OAUTH_TEAM_ID=
# APPLE_OAUTH_KEY_ID=
# APPLE_OAUTH_PRIVATE_KEY=
# APPLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/oauth/apple/callback
